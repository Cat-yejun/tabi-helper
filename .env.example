# --- Supabase ---
# Supabase 프로젝트 > Settings > API 에서 복사
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...

# --- Anthropic (LLM: 영수증 분석/일정/번역/비서) ---
# https://console.anthropic.com 에서 발급. 서버에서만 사용되므로 NEXT_PUBLIC_ 아님!
ANTHROPIC_API_KEY=sk-ant-...
# 선택: 모델 변경 가능 (기본값 claude-sonnet-4-6)
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Google Speech-to-Text (실시간 음성 번역용) ---
# Google Cloud Console에서 "Cloud Speech-to-Text API" 활성화 후 발급한 키
GOOGLE_SPEECH_API_KEY=AIza...

# --- Google Maps ---
# 브라우저 지도 표시용 (Maps JavaScript API). HTTP 리퍼러 제한 권장
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIza...
# 서버 길찾기용 (Directions API). IP/없음 제한 권장. 위와 다른 키 권장
GOOGLE_MAPS_SERVER_KEY=AIza...
